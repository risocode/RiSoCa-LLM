{
  "name": "risoca-ai-agent",
  "version": "0.1.0",
  "description": "Local-first project intelligence agent — scan, index, store, report",
  "type": "module",
  "main": "dist/main.js",
  "scripts": {
    "postinstall": "node scripts/rebuild-native.mjs",
    "preflight": "tsx src/preflight-cli.ts",
    "doctor": "tsx src/main.ts doctor",
    "check": "npm run preflight && npm test && npm run build",
    "rebuild:native": "node scripts/rebuild-native.mjs",
    "setup": "npm install && npm run preflight",
    "dev": "tsx src/main.ts",
    "scan": "tsx src/main.ts scan",
    "analyze": "tsx src/main.ts analyze",
    "write": "tsx src/main.ts write",
    "edit": "tsx src/main.ts edit",
    "delete": "tsx src/main.ts delete",
    "approve": "tsx src/main.ts approve",
    "reject": "tsx src/main.ts reject",
    "snapshots": "tsx src/main.ts snapshots",
    "restore": "tsx src/main.ts restore",
    "cmd": "tsx src/main.ts cmd",
    "git:status": "tsx src/main.ts git-status",
    "git:diff": "tsx src/main.ts git-diff",
    "pending": "tsx src/main.ts pending",
    "local:status": "tsx src/main.ts local-status",
    "local:ask": "tsx src/main.ts ask . \"What does this project do?\"",
    "fix": "tsx src/main.ts fix",
    "refactor": "tsx src/main.ts refactor",
    "workflows": "tsx src/main.ts workflows",
    "workflow": "tsx src/main.ts workflow",
    "cancel-workflow": "tsx src/main.ts cancel-workflow",
    "ask": "tsx src/main.ts ask",
    "test": "vitest run",
    "build": "tsc"
  },
  "keywords": ["ai", "agent", "scanner", "indexer"],
  "license": "UNLICENSED",
  "private": true,
  "engines": {
    "node": ">=22.0.0 <23.0.0"
  },
  "dependencies": {
    "better-sqlite3": "^11.9.1",
    "commander": "^13.1.0",
    "fast-glob": "^3.3.3",
    "ignore": "^7.0.4",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "vitest": "^3.0.9"
  }
}
